# Copy to .env and fill in the required values,
# or run scripts/setup-guacamole.sh to generate everything automatically.

# ── Required ────────────────────────────────────────────────────────────────

# DOSM admin account - username (optional, defaults to "admin") + password
DOSM_ADMIN_USERNAME=admin
DOSM_ADMIN_PASSWORD=changeme

# Guacamole Postgres password (generate: openssl rand -hex 16)
GUACAMOLE_DB_PASSWORD=

# Guacamole JSON auth secret - must match dosm-home/config/guacamole.key
# (generate: openssl rand -hex 16, or run scripts/setup-guacamole.sh)
GUACAMOLE_JSON_SECRET_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────

# Port overrides
# DOSM_PORT=8765
# GUACAMOLE_PORT=8888
# OLLAMA_PORT=11435

# LLM model served by Ollama
# DOSM_LLM_MODEL=qwen2.5:3b-instruct

# Browser-facing Guacamole URL (change if behind a reverse proxy)
# GUACAMOLE_PUBLIC_URL=http://localhost:8888/guacamole

# Networks allowed to send auth-json tokens to Guacamole
# GUACAMOLE_JSON_TRUSTED_NETWORKS=127.0.0.1,::1,172.16.0.0/12

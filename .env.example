# Copy to `.env` for `docker compose up`. None of these are read by the DOSM
# Python app — only by docker-compose.yml.

# Postgres password used by the Guacamole webapp's auth DB.
GUACAMOLE_DB_PASSWORD=changeme-strong-password

# 128-bit shared secret (32 hex chars) for the auth-json extension. Generate
# the same value DOSM uses with: dosm guacamole keygen
GUACAMOLE_JSON_SECRET_KEY=00112233445566778899aabbccddeeff

# Networks Guacamole accepts auth-json POSTs from. Localhost + the default
# Docker bridge by default; tighten in production.
GUACAMOLE_JSON_TRUSTED_NETWORKS=127.0.0.1,::1,172.16.0.0/12

# Host port to expose the Guacamole webapp on.
GUACAMOLE_PORT=8080

# Host path mounted into the Guacamole container at /recordings. Must match
# the `guacamole.recordings_dir` value in DOSM's config.yaml so the UI can
# locate replays later.
GUACAMOLE_RECORDINGS_HOST_DIR=./.dosm-home/data/guacamole_recordings
